# Scope Tracker Environment Variables
# Copy this file to .env.local for local development
# Copy to .env.production for production deployment

# ============ Database ============
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-key
DATABASE_URL=postgresql://user:password@db.example.com:5432/scope_tracker

# ============ Authentication ============
# If using Supabase auth, these are auto-configured
# For custom auth, set these:
AUTH_SECRET=your-secret-key
AUTH_PROVIDERS=google,microsoft

# ============ External APIs ============
# Clio Practice Management
CLIO_API_URL=https://api.clio.com/v4
CLIO_API_KEY=your-clio-api-key
CLIO_WEBHOOK_SECRET=your-webhook-secret

# PracticePanther
PRACTICEPANTHER_API_URL=https://api.practicepanther.com
PRACTICEPANTHER_API_KEY=your-pp-api-key
PRACTICEPANTHER_WEBHOOK_SECRET=your-webhook-secret

# ============ Payments & Invoicing ============
STRIPE_API_KEY=sk_live_your-key
STRIPE_WEBHOOK_SECRET=whsec_your-secret
STRIPE_PUBLISHABLE_KEY=pk_live_your-key

# ============ Email Service ============
# Using Resend for transactional emails
RESEND_API_KEY=re_your-api-key
RESEND_FROM_EMAIL=scope-tracker@firm.example.com
RESEND_FROM_NAME=Scope Tracker

# Alternative: SendGrid
# SENDGRID_API_KEY=SG.xxx

# ============ Automation & Workflows ============
# n8n Workflow Engine
N8N_URL=http://localhost:5678
N8N_API_KEY=your-n8n-api-key

# Trigger.dev Job Processing
TRIGGER_API_KEY=tr_dev_xxx
TRIGGER_API_URL=https://api.trigger.dev
TRIGGER_ENVIRONMENT_ID=dev

# ============ Application Settings ============
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# Blended hourly rate for fixed-fee engagements (default cost per hour)
BLENDED_HOURLY_RATE=250

# Drift Detection Thresholds
DRIFT_WARNING_BUDGET_PERCENT=75
DRIFT_WARNING_COMPLETION_PERCENT=50
DRIFT_CRITICAL_BUDGET_PERCENT=90
DRIFT_CRITICAL_COMPLETION_PERCENT=25
UNSCOPED_WORK_THRESHOLD_HOURS=2

# Change Order Settings
CHANGE_ORDER_AUTO_GENERATE_ON_CRITICAL=true
CHANGE_ORDER_REVIEW_DEADLINE_DAYS=3

# Email Alert Recipients
ALERT_EMAIL_RECIPIENTS=partner@firm.example.com,managing-partner@firm.example.com
ALERT_EMAIL_CC=finance@firm.example.com

# ============ Feature Flags ============
ENABLE_CLIO_IMPORT=true
ENABLE_PRACTICEPANTHER_IMPORT=true
ENABLE_STRIPE_INVOICING=true
ENABLE_AUTO_CHANGE_ORDERS=true
ENABLE_WEEKLY_DIGEST=true

# ============ Monitoring & Analytics ============
# Sentry error tracking
SENTRY_DSN=https://xxx@sentry.io/xxx
SENTRY_ENVIRONMENT=production

# PostHog analytics
POSTHOG_API_KEY=phc_xxx
POSTHOG_API_URL=https://app.posthog.com

# ============ Development ============
# Disable SSL verification for local dev (NOT for production)
NODE_TLS_REJECT_UNAUTHORIZED=0

# Verbose logging for troubleshooting
DEBUG=scope-tracker:*

# Allow CORS from localhost during development
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# ============ Security ============
# JWT secret for API authentication
JWT_SECRET=your-super-secret-key-change-in-production
JWT_EXPIRES_IN=7d

# CSRF protection
CSRF_ENABLED=true
CSRF_COOKIE_SECURE=true

# Rate limiting
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_MS=900000
