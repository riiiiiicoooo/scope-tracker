{
  "tools": [
    {
      "name": "check_scope_drift",
      "displayName": "Check Scope Drift Status",
      "description": "Analyze scope drift for an engagement by comparing planned vs actual hours, budget, schedule, and unplanned scope items. Returns drift metrics, alerts, and recommendations.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "engagement_id": {
            "type": "string",
            "description": "Engagement identifier (e.g., 'ENG-2024-001')"
          },
          "tenant_id": {
            "type": "string",
            "description": "Tenant identifier"
          }
        },
        "required": ["engagement_id", "tenant_id"]
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "generate_change_order",
      "displayName": "Generate Change Order",
      "description": "Create a change order document for scope changes with impact analysis on hours, budget, and schedule. Returns markdown ready for client review and approval.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "engagement_id": {
            "type": "string",
            "description": "Engagement identifier"
          },
          "reason": {
            "type": "string",
            "description": "Description of the scope change (e.g., 'Client requested additional user permissions module')"
          },
          "impact_hours": {
            "type": "integer",
            "description": "Optional: estimated additional hours required",
            "minimum": 0
          },
          "impact_budget": {
            "type": "number",
            "description": "Optional: estimated cost impact in USD",
            "minimum": 0
          },
          "tenant_id": {
            "type": "string",
            "description": "Tenant identifier"
          }
        },
        "required": ["engagement_id", "reason", "tenant_id"]
      },
      "annotations": {
        "readOnlyHint": false,
        "openWorldHint": false
      }
    },
    {
      "name": "get_time_entries",
      "displayName": "Get Time Entries",
      "description": "Fetch time entries for an engagement with optional filtering by date range or resource. Returns entries grouped by phase and allocated work.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "engagement_id": {
            "type": "string",
            "description": "Engagement identifier"
          },
          "date_range": {
            "type": "object",
            "properties": {
              "start": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "Start date (YYYY-MM-DD)"
              },
              "end": {
                "type": "string",
                "pattern": "^\\d{4}-\\d{2}-\\d{2}$",
                "description": "End date (YYYY-MM-DD)"
              }
            },
            "description": "Optional: filter to date range"
          },
          "resource_id": {
            "type": "string",
            "description": "Optional: filter to specific team member"
          },
          "tenant_id": {
            "type": "string",
            "description": "Tenant identifier"
          }
        },
        "required": ["engagement_id", "tenant_id"]
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": false
      }
    },
    {
      "name": "list_engagements",
      "displayName": "List Engagements",
      "description": "Get list of all engagements with status and scope drift indicators. Quick portfolio overview for identifying at-risk projects.",
      "inputSchema": {
        "type": "object",
        "properties": {
          "tenant_id": {
            "type": "string",
            "description": "Tenant identifier"
          },
          "status_filter": {
            "type": "string",
            "enum": ["active", "planning", "closed", "on_hold"],
            "description": "Optional: filter by engagement status"
          }
        },
        "required": ["tenant_id"]
      },
      "annotations": {
        "readOnlyHint": true,
        "openWorldHint": false
      }
    }
  ]
}
